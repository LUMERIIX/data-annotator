{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Theater Play Inventory Schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "language": {
      "enum": [
        "German",
        "English",
        "Swiss_German"
      ]
    },
    "variants": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PlayVariant"
      }
    }
  },
  "required": [
    "name",
    "language",
    "variants"
  ],
  "definitions": {
    "PlayVariant": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "e.g., 'Premiere' or 'GP'"
        },
        "duration": {
          "type": "integer",
          "description": "duration in ms"
        },
        "audio_quality": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "description": "1: Bad, 2: Medium, 3: Good"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Section"
          }
        }
      },
      "required": [
        "name",
        "sections",
        "duration",
        "audio_quality"
      ]
    },
    "Section": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "start": {
          "type": "integer",
          "minimum": 0,
          "description": "Timestamp in milliseconds"
        },
        "stop": {
          "type": "integer",
          "minimum": 1,
          "description": "Timestamp in milliseconds"
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PlayEvent"
          }
        },
        "cues": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Cue"
          }
        }
      },
      "required": [
        "name",
        "start",
        "stop",
        "events",
        "cues"
      ]
    },
    "SpeechSituation": {
      "type": "object",
      "properties": {
        "SpeechSituationType": {
          "enum": [
            "SingleSpeaker",
            "Dialog",
            "Interleaved"
          ]
        },
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "stop": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "SpeechSituationType",
        "start",
        "stop"
      ]
    },
    "Cue": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "CueType": {
          "enum": [
            "Audio",
            "Video",
            "Light"
          ]
        },
        "TriggerStrategy": {
          "enum": [
            "WordBeginning",
            "WordEnd",
            "Visual"
          ]
        },
        "anchor": {
          "type": "string",
          "description": "Description which anchor triggered the cue (word or event on stage)"
        },
        "delay": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "start",
        "CueType",
        "TriggerStrategy",
        "anchor"
      ]
    },
    "PlayEvent": {
      "type": "object",
      "properties": {
        "PlayEventType": {
          "enum": [
            "BadAudio",
            "Paraphrase",
            "MissingText",
            "AdditionalText",
            "Improvisation",
            "LanguageDeviation",
            "SwitchedOrder"
          ]
        },
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "stop": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "PlayEventType",
        "start",
        "stop"
      ]
    }
  }
}